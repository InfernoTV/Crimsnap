{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crimsnap",
  "version": "0.1.0",
  "identifier": "lol.crimsnap.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Crimsnap",
        "width": 960,
        "height": 660,
        "minWidth": 860,
        "minHeight": 580,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBNzM0RUU0Qzk1OTMxNEEKUldSS01Wbko1RTV6Mmo4eHhmaG5PbkxucmZ0SVVoVCtkbWNrdVgwWm9RckNpNDVSZzErd1FUem8K",
      "endpoints": [
        "https://github.com/InfernoTV/crimsnap/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
